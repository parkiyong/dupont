{
    "app-id": "io.github.parkiyong.dupont",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "dupont-app",
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "build-args": [
            "--share=network"
        ],
        "env": {
            "CARGO_HOME": "/run/build/dupont/cargo"
        }
    },
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=~/.config/dupont:create",
        "--filesystem=~/.cache/dupont:create",
        "--talk-name=org.freedesktop.portal.Desktop"
    ],
    "cleanup": [
        "/include",
        "*.a",
        "/lib/debug"
    ],
    "modules": [
        {
            "name": "dupont",
            "buildsystem": "simple",
            "build-commands": [
                "cargo --offline build --release --frozen --manifest-path Cargo.toml -p dupont-domain -p dupont-app",
                "install -Dm755 target/release/dupont-app /app/bin/dupont-app",
                "install -Dm644 data/io.github.parkiyong.dupont.desktop /app/share/applications/io.github.parkiyong.dupont.desktop",
                "install -Dm644 data/icons/scalable/io.github.parkiyong.dupont.svg /app/share/icons/hicolor/scalable/apps/io.github.parkiyong.dupont.svg",
                "install -Dm644 data/icons/symbolic/io.github.parkiyong.dupont-symbolic.svg /app/share/icons/hicolor/symbolic/apps/io.github.parkiyong.dupont-symbolic.svg"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/parkiyong/dupont.git",
                    "tag": "v1.2"
                },
                {
                    "type": "inline",
                    "contents": "[source.crates-io]\nreplace-with = \"vendored-sources\"\n\n[source.vendored-sources]\ndirectory = \"/run/build/dupont/cargo/vendor\"\n",
                    "dest": "cargo/config.toml",
                    "dest-filename": "config.toml"
                },
                "cargo-sources.json"
            ]
        }
    ]
}
